    "identifier":"SEAT-79",
    "uid":"25q:25_",
    "sourceUid":"25q",
    "name":"Activation Conditions",
    "description":"The system shall only be active while the following conditions are met: \r\n- the seat is occupied\r\n- the power status reads OK\r\n- there is no error (error flag: 0)\r\n",
    "externalUUID":"subterra:data-service:objects:/default/seatheater${WorkItem}SEAT-79",
