    "isConfirmed":"true"
  }, {
    "identifier":"SEAT-80",
    "uid":"25q:25b",
    "sourceUid":"25q",
    "name":"Reactivation",
    "description":"When the system is reactivated (activation conditions are once again met) it shall return to the same temperature stage that was active before.",
    "externalUUID":"subterra:data-service:objects:/default/seatheater${WorkItem}SEAT-80",
    "localId":"SEAT-80",
    "url":"http://polarion03.prom.local/polarion/redirect/project/seatheater/workitem?id=SEAT-80",
